# ============================================
# Authentication Configuration
# ============================================
# Secret key for JWT token generation (required for production)
# Generate with: openssl rand -hex 32
AUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-hex-32

# Password for dashboard login (required for production)
# Default: admin (change this in production!)
AUTH_PASSWORD=admin

# ============================================
# Server Configuration
# ============================================
# Public server host for connecting to ZeroClaw instances
# Defaults to localhost if not set
NEXT_PUBLIC_SERVER_HOST=localhost

# ============================================
# Docker Configuration
# ============================================
# Workspace root directory for instance data
# Defaults to ./workspace if not set
WORKSPACE_ROOT=./workspace

# Host UID and GID for Docker container permissions
# Defaults to current user's UID/GID if not set
HOST_UID=1000
HOST_GID=1000

# ============================================
# Docker Compose Configuration
# ============================================
# ClawPond dashboard port (default: 3000)
CLAWPOND_PORT=3000

# ============================================
# Environment
# ============================================
# Node environment (development, production)
# Defaults to development if not set
NODE_ENV=development
