# ============================================
# Authentication Configuration
# ============================================
# Authentication token for accessing the dashboard (REQUIRED)
# This is the main authentication method used by ClawPond
# Generate a secure token with: openssl rand -hex 32
# Default: a0421e2f9e6811518d3ad7ad7b51d6732c1dabc2df8fa011027a9920062b85d0 (CHANGE THIS IN PRODUCTION!)
AUTH_TOKEN=a0421e2f9e6811518d3ad7ad7b51d6732c1dabc2df8fa011027a9920062b85d0

# ============================================
# Server Configuration
# ============================================
# Public server host for connecting to ZeroClaw instances
# Defaults to localhost if not set
NEXT_PUBLIC_SERVER_HOST=localhost

# ============================================
# Docker Configuration
# ============================================
# Workspace root directory for instance data
# Defaults to ./workspace if not set
WORKSPACE_ROOT=./workspace

# Host UID and GID for Docker container permissions
# Defaults to current user's UID/GID if not set
HOST_UID=1000
HOST_GID=1000

# ============================================
# Docker Compose Configuration
# ============================================
# ClawPond dashboard port (default: 3000)
CLAWPOND_PORT=3000

# ============================================
# Environment
# ============================================
# Node environment (development, production)
# Defaults to development if not set
NODE_ENV=development
