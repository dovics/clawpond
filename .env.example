# ============================================
# Authentication Configuration
# ============================================
# Authentication token for accessing the dashboard (REQUIRED)
# This is the main authentication method used by ClawPond
# Generate a secure token with: openssl rand -hex 32
# Default: a0421e2f9e6811518d3ad7ad7b51d6732c1dabc2df8fa011027a9920062b85d0 (CHANGE THIS IN PRODUCTION!)
AUTH_TOKEN=a0421e2f9e6811518d3ad7ad7b51d6732c1dabc2df8fa011027a9920062b85d0

# ============================================
# Server Configuration
# ============================================
# Public server host for connecting to ZeroClaw instances
# Defaults to localhost if not set
NEXT_PUBLIC_SERVER_HOST=localhost

# ============================================
# Docker Configuration
# ============================================
# Mount workspace root directory inside container (for Docker bind mounts)
# When running in Docker, this should be set to /app/workspace
# When running locally, this defaults to ./workspace
MOUNT_WORKSPACE_ROOT=/app/workspace

# ZeroClaw container image (default: dovics1/zeroclaw:v0.1.7-beta.30-local-0.1.3-fea53a8)
# You can override this to use a different ZeroClaw image version
ZEROCLAW_IMAGE=dovics1/zeroclaw:v0.1.7-beta.30-local-0.1.3-fea53a8

# ============================================
# Docker Compose Configuration
# ============================================
# ClawPond dashboard port (default: 3000)
CLAWPOND_PORT=3000

# ============================================
# Environment
# ============================================
# Node environment (development, production)
# Defaults to development if not set
NODE_ENV=development
